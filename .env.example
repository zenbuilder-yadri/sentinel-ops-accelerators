# ── Sentinel-Ops Accelerators — shared example env ───────────────────────────
# Copy to .env (gitignored) and fill. Mode 1 uses SOE_JWT; Mode 2 uses SOE_API_KEY.
SOE_API_URL=https://api.yadriworks.ai
SOE_TENANT_ID=yadriworks-demo

# Mode 1 (SDK) — operator JWT (Bearer).
SOE_JWT=

# Mode 2 (sidecar) — long-lived API key (sok_..., role=editor).
SOE_API_KEY=

# Both modes — Anthropic key for the LLM.
ANTHROPIC_API_KEY=

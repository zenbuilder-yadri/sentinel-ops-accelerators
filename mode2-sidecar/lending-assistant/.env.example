# LendingAssistant — Mode 2 (transparent sidecar)
SOE_API_URL=https://api.yadriworks.ai
SOE_TENANT_ID=yadriworks-demo
SOE_APP_ID=lending-assistant-mode2
# REQUIRED — long-lived sidecar API key (sok_...), role=editor.
SOE_API_KEY=
# Outage demo: set to 'closed' to deny egress when control plane unreachable.
SOE_CIRCUIT_BREAKER_FAIL_MODE=closed
# REQUIRED — Anthropic key for the agent's LLM (allow-listed egress).
ANTHROPIC_API_KEY=

# LendingAssistant — Mode 2 (transparent sidecar)
SOE_API_URL=https://api.yadriworks.ai
SOE_TENANT_ID=yadriworks-demo
SOE_APP_ID=lending-assistant-mode2

# ── Control-plane credential (for audit/tool-eval reporting only) ─────────────
# The EGRESS containment proof needs NO credential — the sidecar decides egress
# locally from the mounted SOE. Provide ONE of the following only if you want the
# central audit trail / tool evaluation:
#   SOE_API_TOKEN — a Bearer JWT (easiest; ~24h lifetime).
#   SOE_API_KEY   — a long-lived sok_... key. NOTE: minting one requires the
#                   tenant ADMIN role (an editor cannot). On your own tenant you
#                   have admin: dashboard, or POST /v1/auth/tenants/<id>/api-keys.
SOE_API_TOKEN=
SOE_API_KEY=

# Override the published sidecar image if you build your own.
# SOE_SIDECAR_IMAGE=us-central1-docker.pkg.dev/pragmatic-braid-467912-u0/sentinel-ops/soe-sidecar:latest

# Outage behavior: 'closed' denies egress when the control plane is unreachable.
SOE_CIRCUIT_BREAKER_FAIL_MODE=closed

# REQUIRED for the chat demo (not for the egress proof): Anthropic LLM key.
ANTHROPIC_API_KEY=

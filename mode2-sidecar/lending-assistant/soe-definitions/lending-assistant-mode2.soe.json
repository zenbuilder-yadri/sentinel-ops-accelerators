{
  "agentId": "lending-assistant-mode2",
  "version": "1.0.0",
  "schemaVersion": "1.0",
  "description": "LendingAssistant \u2014 Mode 2 (transparent sidecar). Consumer-lending loan officer. The agent has zero SOE awareness; containment is enforced at the network egress. It may reach the credit bureau, the internal loan-origination system, the mail relay, and the LLM provider \u2014 and NOTHING else. Even a fully prompt-injected agent cannot exfiltrate applicant PII.",
  "identity": {
    "role": "LoanOfficerAgent",
    "allowedPersonas": [
      "lending-assistant-mode2",
      "loan-officer"
    ],
    "authorityLevel": "process-applications",
    "environmentScope": [
      "development",
      "uat",
      "production"
    ],
    "dataClassification": "restricted",
    "regulatoryContext": [
      "FCRA",
      "ECOA",
      "GLBA"
    ]
  },
  "dataAccess": {
    "readAllow": [
      "applications/**",
      "bureau/**",
      "los/**"
    ],
    "readDeny": [
      "**/.env*",
      "**/credentials*",
      "**/secrets*"
    ],
    "writeAllow": [
      "decisions/**"
    ],
    "writeDeny": [
      "**/production/**"
    ]
  },
  "toolActions": {
    "allowed": [
      "pull_credit_report",
      "check_eligibility",
      "send_decision_email"
    ],
    "denied": [],
    "bash": {
      "allow": [],
      "deny": [
        "rm -rf *",
        "sudo *"
      ]
    }
  },
  "transport": {
    "network": {
      "egressAllow": [
        "api.anthropic.com",
        "api.equifax.com",
        "api.socure.com",
        "api.middesk.com",
        "api.dwolla.com",
        "api.stripe.com",
        "mock-bureau",
        "mock-los",
        "mock-mail"
      ],
      "egressDeny": [
        "169.254.169.254",
        "attacker.example",
        "*.attacker.example",
        "pastebin.com",
        "*.pastebin.com",
        "transfer.sh",
        "*.onion",
        "10.0.0.0/8",
        "example.com"
      ]
    }
  },
  "riskBudget": {
    "maxPerSession": 40,
    "thresholds": {
      "warn": 20,
      "throttle": 30,
      "critical": 36,
      "exhausted": 40
    }
  },
  "mode": "enforce"
}